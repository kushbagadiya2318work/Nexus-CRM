# Copy these into the Vercel Project Settings → Environment Variables panel.
# All variables are read by the serverless function at runtime.

# --- Required ---
JWT_ACCESS_SECRET=replace_with_secure_access_secret
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret

# --- Optional / strongly recommended ---
# If unset the API runs in in-memory demo mode (data is reset every cold start).
MONGO_URI=mongodb+srv://user:pass@cluster/nexus-crm

# Comma-separated list of additional allowed origins. The deployment URL
# (VERCEL_URL) is always allowed automatically.
FRONTEND_URL=https://your-custom-domain.com

# --- Integrations (all optional) ---
META_ACCESS_TOKEN=
META_PAGE_ID=
META_VERIFY_TOKEN=

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
IVR_AGENT_NUMBER=

# --- Frontend build-time variables (prefix with VITE_) ---
# Leave unset to use the same-origin /api default in production.
# VITE_CRM_API_URL=https://your-other-api.example.com/api
