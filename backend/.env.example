# =============================================================================
# Nexus-CRM Backend — Environment Variables
# Copy this file to `.env` (local dev) and fill in real values.
# In production (Vercel), configure these in Project Settings → Environment Variables.
# =============================================================================

# ---- Core server ------------------------------------------------------------
PORT=4000
NODE_ENV=development
# Standalone Express server only — Vercel sets this automatically.
# SERVERLESS=1   # set to skip app.listen() when running as a Vercel function

# ---- CORS / frontend --------------------------------------------------------
# Comma-separated list of allowed frontend origins (in addition to localhost).
# Production example: https://nexus-crm-v3x7.vercel.app
FRONTEND_URL=http://localhost:5173

# ---- Database ---------------------------------------------------------------
# Optional. If omitted, the API runs against the in-memory store (dev only).
MONGO_URI=mongodb://127.0.0.1:27017/nexus-crm

# ---- Auth (JWT) -------------------------------------------------------------
# Generate strong random strings, e.g. `openssl rand -hex 64`
JWT_ACCESS_SECRET=replace_with_secure_access_secret
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret

# ---- Bootstrap admin user (seeded on first boot if no users exist) ----------
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=change_me_now

# ---- Meta / Facebook Lead Ads ----------------------------------------------
META_ACCESS_TOKEN=your_meta_access_token
META_PAGE_ID=your_meta_page_id
META_VERIFY_TOKEN=your_meta_verify_token
META_APP_SECRET=your_meta_app_secret

# ---- WhatsApp Cloud API -----------------------------------------------------
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_whatsapp_verify_token
WHATSAPP_APP_SECRET=your_whatsapp_app_secret

# ---- Telephony (SMS / Click-to-Call) ----------------------------------------
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_number
EXOTEL_API_KEY=your_exotel_key
EXOTEL_API_TOKEN=your_exotel_token
IVR_AGENT_NUMBER=your_sales_team_number

# ---- Email (choose one provider) -------------------------------------------
# Option A: webhook (Zapier/Make/n8n forwarder)
LEAD_EMAIL_WEBHOOK_URL=
# Option B: Resend
RESEND_API_KEY=
# Option C: SMTP (used if neither of the above is set)
SMTP_HOST=

# ---- Notifications & automation sinks ---------------------------------------
SLACK_WEBHOOK_URL=
ZAPIER_WEBHOOK_URL=
MAKE_WEBHOOK_URL=

# ---- Web Push (browser notifications) ---------------------------------------
# Generate with: `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ---- Vercel (auto-injected in production — do not set locally) --------------
# VERCEL=1
# VERCEL_URL=nexus-crm-v3x7.vercel.app
